# Slack App
SLACK_BOT_TOKEN=xoxb-...          # Bot User OAuth Token
SLACK_SIGNING_SECRET=...          # Signing Secret (тільки для app.py)
SLACK_CHANNEL_ID=C...             # ID каналу алертів (правий клік → Copy channel ID)

# GitHub Gist (для зберігання замін)
GIST_ID=abc123...                 # ID gist (з URL: gist.github.com/user/<ID>)
GIST_TOKEN=ghp_...                # GitHub PAT зі scope: gist

# Патерни алертів (через кому)
ALERT_PATTERNS=FIRING,CRITICAL,ALERT
